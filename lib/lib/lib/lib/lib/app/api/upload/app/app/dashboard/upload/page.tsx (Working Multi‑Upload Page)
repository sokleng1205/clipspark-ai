"use client";
import { useState } from "react";
import UploadZone from "@/components/dashboard/UploadZone";
import VideoPreview from "@/components/dashboard/VideoPreview";
import { motion } from "framer-motion";

export default function UploadPage() {
  const [videos, setVideos] = useState<File[]>([]);

  return (
    <div className="p-4 md:p-8 max-w-7xl mx-auto">
      <motion.h1 initial={{opacity:0}} animate={{opacity:1}} className="text-3xl md:text-4xl font-bold mb-6">
        Upload Your Long Videos
      </motion.h1>
      <UploadZone videos={videos} setVideos={setVideos} />
      {videos.length > 0 && (
        <div className="mt-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {videos.map((v, i) => (
            <VideoPreview key={i} file={v} />
          ))}
        </div>
      )}
    </div>
  );
}
